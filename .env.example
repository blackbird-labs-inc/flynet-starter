# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# Flynet Discovery API key (sent as X-API-Key).
# SERVER-SIDE ONLY — never expose it to the browser.
# It authenticates against staging and returns real Blackbird restaurant and
# location data. Request a key through the Flynet developer portal.
API_KEY=

# (Optional) A member OAuth access token (JWT). Set it to light up the member
# components — the wallet badge and passport. It needs the read:profile and
# read:wallets scopes. Leave blank to skip the member section.
# In production this comes from the OAuth flow, not an env var — see the README.
ACCESS_TOKEN=
